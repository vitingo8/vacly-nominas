# Desarrollo local: company_id inyectado al abrir localhost sin ?company_id=...
# (solo aplica con NODE_ENV=development; en producción sigue bloqueado sin parámetro)
VACLY_NOMINAS_DEV_COMPANY_ID=
# Opcional: user_id UUID para token v2 en desarrollo directo (sin iframe vacly-app)
VACLY_NOMINAS_DEV_USER_ID=
# Mismo secreto que vacly-app — obligatorio en producción para APIs de certificados
ADMIN_SESSION_SECRET=
# Origen de vacly-app (iframe padre) para validar postMessage de sesión
NEXT_PUBLIC_VACLY_APP_URL=https://www.vacly.es

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# IA (nóminas)
ANTHROPIC_API_KEY=

# Integraciones administrativas TGSS/AEAT (modo real)
ADMIN_INTEGRATIONS_ENABLED=true
TGSS_SILTRA_INPUT_DIR=C:\SILTRA\in
TGSS_SILTRA_OUTPUT_DIR=C:\SILTRA\out
TGSS_SILTRA_EXECUTABLE_PATH=C:\SILTRA\siltra.exe
TGSS_CERTIFICATE_ID=
AEAT_MODE=soap
# Clave para cifrar certificados .pfx (obligatoria, mín. 32 caracteres).
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_ENCRYPTION_KEY=
ADMIN_STORAGE_BUCKET=admin-integrations
CRON_SECRET=

# Notificaciones administrativas (AEAT + TGSS WSCN + DEHú LEMA) — conectores SOAP reales
ADMIN_NOTIFICATIONS_ENABLED=true
# sandbox | production
ADMIN_NOTIFICATIONS_ENV=production
ADMIN_NOTIFICATIONS_LOOKBACK_DAYS=90
AEAT_NOTIFICATIONS_ENABLED=true
TGSS_WSCN_ENABLED=true
DEHU_LEMA_ENABLED=false
# Opcional: sobreescribir endpoints
# AEAT_CONSULTA_ENDPOINT=
# AEAT_ACCESO_ENDPOINT=
# AEAT_AUTORIZADOS_ENDPOINT=
# TGSS_WSCN_ENDPOINT=
# DEHU_LEMA_ENDPOINT=
