# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# IA (nóminas)
ANTHROPIC_API_KEY=

# Integraciones administrativas TGSS/AEAT
ADMIN_INTEGRATIONS_ENABLED=true
TGSS_MODE=mock
TGSS_SILTRA_INPUT_DIR=
TGSS_SILTRA_OUTPUT_DIR=
TGSS_SILTRA_EXECUTABLE_PATH=
TGSS_CERTIFICATE_ID=
AEAT_MODE=mock
# Clave para cifrar certificados .pfx (obligatoria en producción, mín. 32 caracteres).
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_ENCRYPTION_KEY=
ADMIN_STORAGE_BUCKET=admin-integrations
CRON_SECRET=
